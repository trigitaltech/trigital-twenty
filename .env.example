# Copy this to /opt/twenty/.env on your EC2 and fill in real values.
# NEVER commit the real .env file.

TAG=latest
SERVER_URL=https://crm.trigitaltech.com

PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=REPLACE_strong_password_no_special_chars

# Generate each with: openssl rand -base64 32
ENCRYPTION_KEY=REPLACE_openssl_rand_base64_32
APP_SECRET=REPLACE_openssl_rand_base64_32

STORAGE_TYPE=s3
STORAGE_S3_REGION=ap-south-1
STORAGE_S3_NAME=trigital-twenty-crm-storage
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=REPLACE_your_aws_access_key_id
STORAGE_S3_SECRET_ACCESS_KEY=REPLACE_your_aws_secret_access_key
